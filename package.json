{
  "name": "client",
  "productName": "SAD Guard",
  "version": "1.2.6",
  "description": "Appliction for validate sad data",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "node scripts/run-forge-with-postgres.js package",
    "make": "node scripts/run-forge-with-postgres.js make",
    "make:remote": "node scripts/make-remote.js",
    "publish": "electron-forge publish",
    "lint": "eslint --no-error-on-unmatched-pattern --ext .ts,.tsx \"src/**/*.ts\" \"src/**/*.tsx\"",
    "raport:schema": "node scripts/generate-raport-schema.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:postgres": "node scripts/run-prisma-postgres-generate.js",
    "prisma:generate:postgres:prod": "node scripts/run-prisma-postgres-generate.js prod",
    "prisma:push:postgres": "node scripts/run-prisma-postgres-command.js db push",
    "prisma:push:postgres:prod:unsafe": "node scripts/run-prisma-postgres-command.js --target prod --allow-prod db push",
    "prisma:migrate:create:postgres": "node scripts/run-prisma-postgres-command.js migrate dev --create-only",
    "prisma:migrate:deploy:postgres": "node scripts/run-prisma-postgres-command.js migrate deploy",
    "prisma:migrate:deploy:postgres:prod": "node scripts/run-prisma-postgres-command.js --target prod --allow-prod migrate deploy",
    "prisma:migrate:status:postgres": "node scripts/run-prisma-postgres-command.js migrate status",
    "prisma:migrate:status:postgres:prod": "node scripts/run-prisma-postgres-command.js --target prod --allow-prod migrate status",
    "prisma:migrate:check:postgres": "node scripts/check-prisma-postgres-migrations.js",
    "seed:super-admin:postgres": "node scripts/seed-postgres-super-admin.js",
    "seed:super-admin:postgres:prod": "node scripts/seed-postgres-super-admin.js --target prod --allow-prod",
    "postinstall": "prisma generate && node scripts/run-prisma-postgres-generate.js"
  },
  "keywords": [],
  "author": {
    "name": "Yehor",
    "email": "egorkorsungit@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.11.0",
    "electron": "40.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "node-loader": "^2.1.0",
    "prisma": "7.2.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.4",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "7.2.0",
    "@prisma/adapter-pg": "7.2.0",
    "@prisma/client": "7.2.0",
    "bootstrap": "^5.3.3",
    "dotenv": "^17.2.3",
    "electron-squirrel-startup": "^1.0.1",
    "pg": "^8.16.3",
    "xlsx": "^0.18.5"
  }
}
